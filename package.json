{
 "name": "cfdi-sync",
 "version": "1.0.0",
 "description": "",
 "keywords": [],
 "license": "ISC",
 "scripts": {
  "build:frontend": "npm run build --workspace=frontend",
  "clean": "rm -rf node_modules package/*/node_modules package-lock.json",
  "dev:backend": "npm run dev --workspace=backend",
  "dev:frontend": "npm run dev --turbo --workspace=frontend",
  "typecheck:backend": "tsc --noEmit -p package/backend/tsconfig.json",
  "typecheck:frontend": "tsc -b package/frontend/tsconfig.json --noEmit",
  "typecheck": "npm run typecheck:backend && npm run typecheck:frontend"
 },
 "workspaces": [
  "package/common",
  "package/frontend",
  "package/backend"
 ]
}
